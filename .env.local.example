# All Zints — Variables de entorno
# Copia este archivo a .env.local y configura los valores

# URL base del sitio (necesaria para SumUp redirects)
NEXT_PUBLIC_BASE_URL=https://allzints.com

# SumUp — Pagos con tarjeta
# Obtén tu API Key en: SumUp Dashboard > Developers > API Keys
# Obtén tu Merchant Code en: SumUp Dashboard > Tu perfil
SUMUP_API_KEY=sup_sk_xxx
SUMUP_MERCHANT_CODE=MXXXXX

# WhatsApp Business (número sin espacios ni guiones)
# NEXT_PUBLIC_WHATSAPP_NUMBER=34600000000

# Analytics (opcional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
